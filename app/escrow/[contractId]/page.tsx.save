function useClientState(contractId: string) {
  const [data, setData] = React.useState<ContractState | null>(null);
  const [loading, setLoading] = React.useState(true);
  const [error, setError] = React.useState<string | null>(null);

  React.useEffect(() => {
    let mounted = true;
    
    async function load() {
      setLoading(true);
      setError(null);
      try {
        const state = await getContractState(contractId);
        if (mounted) {
          setData(state);
          setLoading(false);
        }
      } catch (err) {
        if (mounted) {
          const msg = err instanceof ContractQueryError 
            ? err.message 
            : "Network error. Please check your connection and try again.";
          setError(msg);
          setLoading(false);
        }
      }
    }
    
    load();
    return () => { mounted = false; };
  }, [contractId]);

  return { data, loading, error };
}
